# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Your Supabase project URL
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_ANON_KEY: Your Supabase anonymous API key
SUPABASE_ANON_KEY="your-anon-key"

# Server-side only (Vercel Function / API route)
# IMPORTANT: never expose this in frontend code.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Access request admin notifications (server-side)
BREVO_API_KEY="xkeysib-xxxxxxxx"
ADMIN_NOTIFICATION_EMAIL="admin@empresa.com"

# Optional sender override (must be sender validated in Brevo)
ACCESS_REQUEST_SENDER_EMAIL="noreply@seu-dominio.com"
ACCESS_REQUEST_SENDER_NAME="MFinanceiro"
